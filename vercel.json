{
  "rewrites": [
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/oto-1", "destination": "/oto-1.html" },
    { "source": "/thank-you", "destination": "/thank-you.html" },
    { "source": "/quiz", "destination": "/quiz.html" },
    { "source": "/results", "destination": "/results.html" }
  ],
  "headers": [
    { "source": "/(.*)", "headers": [{"key": "Cache-Control", "value": "public, max-age=3600, must-revalidate"}] }
  ]
}
